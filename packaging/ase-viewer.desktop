[Desktop Entry]
Type=Application
Name=ASE TECH & DESIGN Viewer
GenericName=Markdown Viewer
Comment=Native documentation viewer with TECH and DESIGN modes
Exec=ase-viewer %F
Icon=ase-viewer
Terminal=false
MimeType=text/markdown;text/x-markdown;
Categories=Documentation;Development;TextEditor;
Keywords=markdown;documentation;ase;viewer;
StartupWMClass=com.antarien.ase.viewer
