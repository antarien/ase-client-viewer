# Maintainer: Antarien <dev@antarien.com>
pkgname=ase-viewer
pkgver=0.0.1
pkgrel=1
pkgdesc='ASE TECH & DESIGN Documentation Viewer — Native GTK4 Markdown renderer'
arch=('x86_64')
url='https://github.com/antarien/ase-client-viewer'
license=('custom')
depends=(
    'gtkmm-4.0'
    'libadwaita'
    'graphviz'
    'ttf-fira-code'
    'ttf-nerd-fonts-symbols-mono'
    'otf-stix'
    'otf-stix-math'
)
makedepends=(
    'cmake'
    'ninja'
    'gcc'
    'pkgconf'
    'git'
)
optdepends=(
    'fcitx5-gtk: input method support'
)
source=("git+https://github.com/antarien/ase-client-viewer.git")
sha256sums=('SKIP')

build() {
    cd "$srcdir/ase-client-viewer"
    cmake -B build -G Ninja \
        -DCMAKE_BUILD_TYPE=Release \
        -DCMAKE_INSTALL_PREFIX=/usr
    cmake --build build --parallel
}

package() {
    cd "$srcdir/ase-client-viewer"
    DESTDIR="$pkgdir" cmake --install build

    install -Dm644 packaging/ase-viewer.desktop \
        "$pkgdir/usr/share/applications/ase-viewer.desktop"

    # Brand icons (Down→Top: synced from sha-web-resources/generated/ase/ via build.sh)
    for size in 16 32 48 192 512; do
        install -Dm644 "packaging/icons/icon-${size}.png" \
            "$pkgdir/usr/share/icons/hicolor/${size}x${size}/apps/ase-viewer.png"
    done
}
